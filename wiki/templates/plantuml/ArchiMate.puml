' ArchiMate 3.2 标准库
' 用于 PlantUML 的 ArchiMate 图表定义

' ============================================
' 业务层元素 (Business Layer Elements)
' ============================================

!define Business_Process(e, n) rectangle "<$businessprocess>\nn" as e
!define Business_Service(e, n) rectangle "<$businessservice>\nn" as e
!define Business_Object(e, n) rectangle "<$businessobject>\nn" as e
!define Business_Event(e, n) rectangle "<$businessevent>\nn" as e
!define Business_Function(e, n) rectangle "<$businessfunction>\nn" as e
!define Business_Interaction(e, n) rectangle "<$businessinteraction>\nn" as e
!define Business_Actor(e, n) rectangle "<$businessactor>\nn" as e
!define Business_Role(e, n) rectangle "<$businessrole>\nn" as e
!define Business_Collaboration(e, n) rectangle "<$businesscollaboration>\nn" as e
!define Business_Interface(e, n) rectangle "<$businessinterface>\nn" as e
!define Product(e, n) rectangle "<$product>\nn" as e
!define Contract(e, n) rectangle "<$contract>\nn" as e
!define Representation(e, n) rectangle "<$representation>\nn" as e

' ============================================
' 应用层元素 (Application Layer Elements)
' ============================================

!define Application_Component(e, n) rectangle "<$applicationcomponent>\nn" as e
!define Application_Service(e, n) rectangle "<$applicationservice>\nn" as e
!define Application_Interface(e, n) rectangle "<$applicationinterface>\nn" as e
!define Application_Function(e, n) rectangle "<$applicationfunction>\nn" as e
!define Application_Interaction(e, n) rectangle "<$applicationinteraction>\nn" as e
!define Application_DataObject(e, n) rectangle "<$dataobject>\nn" as e
!define Application_Process(e, n) rectangle "<$applicationprocess>\nn" as e
!define Application_Event(e, n) rectangle "<$applicationevent>\nn" as e

' ============================================
' 技术层元素 (Technology Layer Elements)
' ============================================

!define Technology_Node(e, n) rectangle "<$node>\nn" as e
!define Technology_Device(e, n) rectangle "<$device>\nn" as e
!define Technology_System_Software(e, n) rectangle "<$systemsoftware>\nn" as e
!define Technology_Service(e, n) rectangle "<$technologyservice>\nn" as e
!define Technology_Interface(e, n) rectangle "<$technologyinterface>\nn" as e
!define Technology_Network(e, n) rectangle "<$network>\nn" as e
!define Technology_Function(e, n) rectangle "<$technologyfunction>\nn" as e
!define Technology_Process(e, n) rectangle "<$technologyprocess>\nn" as e
!define Technology_Event(e, n) rectangle "<$technologyevent>\nn" as e
!define Technology_Artifact(e, n) rectangle "<$artifact>\nn" as e
!define Technology_CommunicationPath(e, n) rectangle "<$communicationpath>\nn" as e

' ============================================
' 战略层元素 (Strategy Layer Elements)
' ============================================

!define Resource(e, n) rectangle "<$resource>\nn" as e
!define Capability(e, n) rectangle "<$capability>\nn" as e
!define CourseOfAction(e, n) rectangle "<$courseofaction>\nn" as e

' ============================================
' 动机元素 (Motivation Elements)
' ============================================

!define Stakeholder(e, n) rectangle "<$stakeholder>\nn" as e
!define Driver(e, n) rectangle "<$driver>\nn" as e
!define Assessment(e, n) rectangle "<$assessment>\nn" as e
!define Goal(e, n) rectangle "<$goal>\nn" as e
!define Outcome(e, n) rectangle "<$outcome>\nn" as e
!define Requirement(e, n) rectangle "<$requirement>\nn" as e
!define Constraint(e, n) rectangle "<$constraint>\nn" as e
!define Meaning(e, n) rectangle "<$meaning>\nn" as e
!define Value(e, n) rectangle "<$value>\nn" as e

' ============================================
' 关系类型 (Relationships)
' ============================================

' 结构关系 (Structural Relationships)
!define Composition_Rel(s, t, l) s *-down- t : l
!define Aggregation_Rel(s, t, l) s o-down- t : l
!define Assignment_Rel(s, t, l) s -down-> t : <<assignment>>\nl
!define Realization_Rel(s, t, l) s -up-> t : <<realize>>\nl

' 依赖关系 (Dependency Relationships)
!define Serving_Rel(s, t, l) s -down-> t : <<serving>>\nl
!define Access_Rel(s, t, l) s -down-> t : <<access>>\nl
!define Influence_Rel(s, t, l) s -down-> t : <<influence>>\nl

' 动态关系 (Dynamic Relationships)
!define Triggering_Rel(s, t, l) s -down-> t : <<trigger>>\nl
!define Flow_Rel(s, t, l) s -down-> t : <<flow>>\nl

' 其他关系 (Other Relationships)
!define Specialization_Rel(s, t, l) s -up-|> t : l
!define Association_Rel(s, t, l) s -down-> t : l

' ============================================
